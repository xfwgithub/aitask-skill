{
  "name": "task-management-skill",
  "version": "1.0.0",
  "description": "任务管理技能 - 服务型 Skill",
  "type": "service",
  "entry": "./task-skill",
  "args": ["--server"],
  "port": {
    "default": 8080,
    "env": "TASK_SKILL_PORT"
  },
  "endpoints": {
    "health": "/api/stats",
    "api": "/api",
    "web": "/"
  },
  "init": {
    "script": "./quick-init.sh",
    "commands": [
      "go mod download",
      "go build -o task-skill ."
    ],
    "verify": {
      "command": "echo '{\"function\": \"get_dashboard_stats\"}' | ./task-skill",
      "expect": "total"
    }
  },
  "runtime": {
    "language": "go",
    "version": ">=1.21",
    "dependencies": [
      "github.com/labstack/echo/v4",
      "modernc.org/sqlite"
    ]
  },
  "features": [
    "任务创建",
    "任务查询",
    "任务更新",
    "任务统计",
    "Web 界面",
    "CLI 模式",
    "数据库持久化"
  ],
  "api": {
    "create_task": {
      "method": "POST",
      "path": "/api/tasks",
      "description": "创建新任务"
    },
    "query_tasks": {
      "method": "GET",
      "path": "/api/tasks",
      "description": "查询任务列表"
    },
    "update_status": {
      "method": "PUT",
      "path": "/api/tasks/:uuid/status",
      "description": "更新任务状态"
    },
    "get_stats": {
      "method": "GET",
      "path": "/api/stats",
      "description": "获取统计信息"
    }
  },
  "deployment": {
    "systemd": {
      "service": "task-skill.service",
      "auto_start": true
    },
    "pm2": {
      "name": "task-skill",
      "auto_restart": true
    },
    "docker": {
      "image": "task-skill:latest",
      "port": 8080
    }
  }
}
